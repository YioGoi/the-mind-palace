{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Debug TypeScript (ts-node)",
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/ts-node",
      "args": [
        "${relativeFile}"
      ],
      "cwd": "${workspaceFolder}",
      
      "env": {
        "TS_NODE_PROJECT": "${workspaceFolder}/tsconfig.json"
      },
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "type": "node",
      "request": "attach",
      "name": "Attach to Node.js (9229)",
      "port": 9229,
      "restart": true,
      
      "skipFiles": ["<node_internals>/**"]
    }
  ]
}
